# ===========================================
# THRIFT STORE - Environment Variables
# ===========================================
# Skopiuj ten plik jako .env.local i uzupełnij wartości
# NIGDY nie commituj pliku .env.local do repozytorium!

# -------------------------------------------
# DATABASE (Supabase)
# -------------------------------------------
# Znajdziesz w: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Direct connection (dla migracji)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# -------------------------------------------
# SUPABASE
# -------------------------------------------
# Znajdziesz w: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# -------------------------------------------
# STRIPE
# -------------------------------------------
# Znajdziesz w: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret - po utworzeniu webhooka w Stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# -------------------------------------------
# ADMIN PANEL
# -------------------------------------------
# Ustaw własne silne hasło (min. 12 znaków)
ADMIN_PASSWORD="your-super-secure-password-here"

# Sekret do podpisywania JWT sesji (wygeneruj losowy string 32+ znaków)
# Możesz wygenerować: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-key-min-32-characters"

# -------------------------------------------
# INPOST (ShipX API)
# -------------------------------------------
# Znajdziesz w: Manager Paczek InPost → API → Klucze
INPOST_API_KEY="your-inpost-api-key"
INPOST_ORGANIZATION_ID="your-organization-id"

# Sandbox (testowe) vs Production
INPOST_API_URL="https://sandbox-api-shipx-pl.easypack24.net"
# INPOST_API_URL="https://api-shipx-pl.easypack24.net"

# -------------------------------------------
# APPLICATION
# -------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# W produkcji zmień na:
# NEXT_PUBLIC_APP_URL="https://twoja-domena.com"
